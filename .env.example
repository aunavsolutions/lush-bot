# Token de tu bot de Discord
# Consíguelo en: https://discord.com/developers/applications
DISCORD_TOKEN=tu_token_aqui

# Client ID del bot (para registrar slash commands)
DISCORD_CLIENT_ID=tu_client_id_aqui

# API Key de Gemini
# Consíguelo en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Nombre del bot (cómo se llama a sí mismo internamente)
BOT_NAME=Lush Bot

# Probabilidad de evento random (0-100, default: 3%)
RANDOM_EVENT_CHANCE=3

# Cooldown entre respuestas automáticas (en segundos, default: 30s)
RESPONSE_COOLDOWN=30
